{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "task-manager-pro-tahasaad2.replit.app"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "image": "latest",
        "buildType": "apk",
        "credentialsSource": "remote"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "task-manager-pro-tahasaad2.replit.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "image": "latest",
        "buildType": "app-bundle",
        "credentialsSource": "remote"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "task-manager-pro-tahasaad2.replit.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
